# =============================================================================
# IND Appointments Tracker - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values

# =============================================================================
# REQUIRED - Application Configuration
# =============================================================================

# Base URL of your application (used in emails and links)
BASE_URL=http://localhost:3000

# JWT secret for authentication (generate with: openssl rand -hex 32)
# CRITICAL: Must be set in production!
JWT_SECRET=your-secure-jwt-secret-minimum-32-characters

# =============================================================================
# REQUIRED - Email Configuration (for notifications)
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=IND Appointments

# =============================================================================
# OPTIONAL - Database Configuration
# =============================================================================

# Path to SQLite database (defaults to ./data/ind_appointments.db)
# DB_PATH=/path/to/your/database.db

# =============================================================================
# OPTIONAL - Server Configuration
# =============================================================================

# Server port (defaults to 3000)
PORT=3000

# Server hostname (defaults to localhost)
HOSTNAME=localhost

# Node environment (development or production)
NODE_ENV=development

# =============================================================================
# OPTIONAL - Security Configuration
# =============================================================================

# Bcrypt rounds for password hashing (defaults to 12)
# BCRYPT_ROUNDS=12

# Disable security headers for development (defaults to false)
# DISABLE_SECURITY_HEADERS=false

# =============================================================================
# OPTIONAL - Logging Configuration
# =============================================================================

# Log level: error, warn, info, debug (defaults to info)
LOG_LEVEL=info

# Log file path (defaults to ./logs/app.log)
# LOG_FILE=/path/to/app.log

# =============================================================================
# OPTIONAL - Telegram Bot Configuration
# =============================================================================

# Telegram bot token (get from @BotFather)
# TELEGRAM_BOT_TOKEN=your-bot-token

# Telegram webhook secret (for verifying incoming webhooks)
# TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# OPTIONAL - Pushover Configuration (for push notifications)
# =============================================================================

# Pushover API token (get from pushover.net)
# PUSHOVER_API_TOKEN=your-api-token

# =============================================================================
# OPTIONAL - Rate Limiting Configuration
# =============================================================================

# API rate limit requests per window (defaults to 100)
# RATE_LIMIT_REQUESTS=100

# API rate limit window in milliseconds (defaults to 900000 = 15 minutes)
# RATE_LIMIT_WINDOW_MS=900000

# =============================================================================
# OPTIONAL - Scraper Configuration
# =============================================================================

# IND API delay between requests in ms (defaults to 2000)
# IND_API_DELAY_MS=2000

# Expat center delay between requests in ms (defaults to 500)
# EXPAT_CENTER_DELAY_MS=500

# =============================================================================
# OPTIONAL - Rotterdam IC (Timeblockr) Configuration
# =============================================================================

# Timeblockr API key for Rotterdam International Center
# TIMEBLOCKR_API_KEY=your-timeblockr-api-key

# Timeblockr API base URL (defaults to Rotterdam IC endpoint)
# TIMEBLOCKR_API_BASE=https://10338.api.timeblockr.cloud/v2

# Timeblockr product ID for Rotterdam IC appointment type
# TIMEBLOCKR_PRODUCT_ID=your-product-uuid
