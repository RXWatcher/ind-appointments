    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.6",
    "playwright": "^1.56.1",
    "puppeteer": "^24.27.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwindcss": "^4",
