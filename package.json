{
  "name": "ind-appointments",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "build": "next build",
    "start": "NODE_ENV=production node server.js",
    "lint": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:init": "node scripts/init-db.js",
    "db:reset": "rm -f data/ind_appointments.db && npm run db:init",
    "db:migrate": "node scripts/run-migrations.js"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^7.0.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.5.0",
    "jsonwebtoken": "^9.0.2",
    "next": "^16.1.0",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.6",
    "playwright": "^1.56.1",
    "puppeteer": "^24.27.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4",
    "ws": "^8.18.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.0",
    "typescript": "5.9.2",
    "vitest": "^2.1.0"
  }
}
